---
interface Props {
  slug: string;
}

const { slug } = Astro.props;
---

<style>
  .manifold-embed {
    position: relative;
    left: 50%;
    transform: translateX(-50%);
    width: 90%;
    height: 18rem;
    max-width: 35rem;
  }
</style>

<iframe src={`https://manifold.markets/embed/${slug}`} class="manifold-embed"
></iframe>
