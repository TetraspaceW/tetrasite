<script>
  const logoImage = document.getElementById("logo-image");
  const herDescription = ["StyleGAN", "NovelAI"].map(
    (model) =>
      `Smiling ${model}-generated portrait of an anime girl with white hair in a fluffy bob, pink eyes, a flower-like AI generation artefact in her hair, and a shirt collar.`,
  );

  if (logoImage instanceof HTMLImageElement) {
    const isUwu = new URLSearchParams(window.location.search).has("uwu");
    if (isUwu) {
      logoImage.src = "/vtuber.png";
      logoImage.alt =
        "A VTuber-style logo for Tetraspace. Tetra Space is written on two seperate lines in a sparkling bubble font. Tetra is written in cyan and has diamond-shaped sparkles, and Space is written in magenta and has flower-shaped sparkles. To the left is a gem emoji, to the right is a magnifying glass, and above is a shoggoth.";
    } else {
      logoImage.src = "/her2.png";
      logoImage.alt = herDescription[1];

      logoImage.addEventListener("mouseenter", () => {
        logoImage.src = "/her.png";
        logoImage.alt = herDescription[0];
      });
      logoImage.addEventListener("mouseleave", () => {
        logoImage.src = "/her2.png";
        logoImage.alt = herDescription[1];
      });
    }
  }
</script>

<img id="logo-image" class="her-image" />
<noscript>
  <img
    src="/her.png"
    class="her-image"
    alt="Smiling StyleGAN-generated portrait of an anime girl with white hair in a fluffy bob, pink eyes, a flower-like AI generation artefact in her hair, and a shirt collar."
  />
</noscript>
<center>
  <p>💎</p>
</center>
