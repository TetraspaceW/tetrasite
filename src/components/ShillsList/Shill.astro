---
import type { ShillData } from "./Shills";

interface Props {
  shill: ShillData;
}

const { links, shill: name, type, description } = Astro.props.shill;

const linksList = Array.isArray(links) ? links : [links];
---

<tr>
  <td>{name}</td>
  <td>
    <p>
      {type}. {description}{" "}
      {
        linksList.map((shillLink, idx) =>
          /* prettier-ignore */
          <><a href={shillLink.url}>{shillLink.name} ({shillLink.location})</a>{idx !== linksList.length - 1 ? ", " : ""}</>,
        )
      }.
    </p>
  </td>
</tr>
