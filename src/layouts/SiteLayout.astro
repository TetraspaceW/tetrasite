<style is:global>
  body {
    background-color: LavenderBlush;
    color: DarkMagenta;
    font-size: larger;
    font-family: "Noto Sans", sans-serif;
  }

  .main {
    padding: 0px 10px;
    margin-left: 0;
    margin-right: 0;
  }

  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    font-family: "Noto Serif", serif;
  }

  @media only screen and (min-width: 768px) {
    .main {
      max-width: 768px;
      margin-left: auto;
      margin-right: auto;
    }
  }

  @media only screen and (min-width: 960px) {
    .main {
      max-width: 1024px;
      margin-left: 10%;
      margin-right: 10%;
    }
  }

  @media only screen and (min-width: 1280px) {
    .main {
      margin-left: auto;
      margin-right: auto;
    }
  }

  @media only screen and (min-width: 960px) {
    .table {
      margin-left: -5%;
      margin-right: -5%;
    }
  }

  .table-nowrap-cell {
    white-space: nowrap;
  }
</style>

<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="DarkMagenta" />
    <meta name="description" content="Homepage of Tetraspace" />
    <link rel="manifest" href="/manifest.json" />
    <title>Tetrasite!</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,800;1,900&family=Noto+Serif:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <script is:inline>
      (() => {
        const hash = window.location.hash || "";
        if (!hash.startsWith("#/")) return;

        const route = hash.slice(1);
        const redirects = {
          "/tetraspace-shills-list": "/tetraspace-shills-list",
          "/effective-altruism": "/effective-altruism",
          "/futarchy": "/futarchy",
          "/futarchy/go-to-space": "/futarchy/go-to-space",
          "/glossary": "/glossary",
          "/canary": "/canary",
          "/blog/against-donor-lottery":
            "https://forum.effectivealtruism.org/posts/eWp6raK5iQ8sfvh4M/reasons-why-one-might-not-give-to-a-donor-lottery",
        };

        const target = redirects[route];
        if (!target) return;

        const current = `${window.location.pathname}${window.location.search}`;
        if (current !== target) {
          window.location.replace(target);
        }
      })();
    </script>
    <div class="main"><slot /></div>
  </body>
</html>
