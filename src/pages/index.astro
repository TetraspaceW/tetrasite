---
import { ThingsICareAboutSection } from "../cra-project/components/HomePageSections/ThingsICareAboutSection";
import { ShillsListSection } from "../cra-project/components/HomePageSections/ShillsListSection";
import { ContactMeSection } from "../cra-project/components/HomePageSections/ContactMeSection";
import { FictionWritingSection } from "../cra-project/components/HomePageSections/FictionWritingSection";
import { InvisibleMessageSection } from "../cra-project/components/HomePageSections/InvisibleMessageSection";
import { Logo } from "../components/Logo";
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout>
  <h1 class="homepage-header">Welcome to my web site!</h1>

  <Logo client:only="react" />

  <p>
    This is the home page of 💎 Tetraspace 💎, and is the place for lots of cool
    Tetraspace facts and content!
  </p>
  <ThingsICareAboutSection />
  <ShillsListSection />
  <ContactMeSection />
  <FictionWritingSection />
  <InvisibleMessageSection />
</SiteLayout>
